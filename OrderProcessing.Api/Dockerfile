FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src
COPY ["OrderProcessing.Api/OrderProcessing.Api.csproj", "OrderProcessing.Api/"]
COPY ["OrderProcessing.Shared/OrderProcessing.Shared.csproj", "OrderProcessing.Shared/"]
RUN dotnet restore "OrderProcessing.Api/OrderProcessing.Api.csproj"
COPY . .
RUN dotnet publish "OrderProcessing.Api/OrderProcessing.Api.csproj" -c Release -o /app

FROM mcr.microsoft.com/dotnet/aspnet:10.0
WORKDIR /app
COPY --from=build /app .
EXPOSE 8080
ENTRYPOINT ["dotnet", "OrderProcessing.Api.dll"]
