@page "/"
@rendermode InteractiveServer
@inject OrderApiClient Api
@inject CartService Cart

<PageTitle>Products - Order Processing</PageTitle>

<h2>Products</h2>

<div class="row mb-3">
    <div class="col">
        <div class="btn-group">
            <button class="btn @(selectedCategory == null ? "btn-primary" : "btn-outline-primary")" @onclick="() => FilterByCategory(null)">All</button>
            @foreach (var cat in categories)
            {
                <button class="btn @(selectedCategory == cat ? "btn-primary" : "btn-outline-primary")" @onclick="() => FilterByCategory(cat)">@cat</button>
            }
        </div>
    </div>
</div>

@if (products is null)
{
    <p>Loading products...</p>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in filteredProducts)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@product.Name</h5>
                        <p class="card-text text-muted">@product.Description</p>
                        <p class="card-text"><strong>@product.Price.ToString("C")</strong></p>
                        <span class="badge bg-secondary mb-2">@product.Category</span>
                        <span class="badge @(product.StockQuantity > 5 ? "bg-success" : "bg-warning") mb-2">Stock: @product.StockQuantity</span>
                    </div>
                    <div class="card-footer">
                        <button class="btn btn-primary btn-sm" @onclick="() => AddToCart(product)">Add to Cart</button>
                        <a href="/product/@product.Id" class="btn btn-outline-secondary btn-sm">Details</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<ProductDto>? products;
    private string? selectedCategory;
    private List<string> categories = new();

    private IEnumerable<ProductDto> filteredProducts =>
        selectedCategory is null ? products ?? new() : (products ?? new()).Where(p => p.Category == selectedCategory);

    protected override async Task OnInitializedAsync()
    {
        products = await Api.GetProductsAsync();
        categories = products.Select(p => p.Category).Distinct().OrderBy(c => c).ToList();
    }

    private void FilterByCategory(string? category) => selectedCategory = category;

    private void AddToCart(ProductDto product)
    {
        Cart.AddItem(product);
    }
}
